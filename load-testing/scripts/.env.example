# Copy to .env in this directory (load-testing/scripts/)
#   cp .env.example .env
#   ./run-load-test.sh
#
# Prerequisites:
#   - AWS CLI v2, jq, curl
#   - CDK stack deployed (load-testing/infra)
#   - Metrics EC2: SSM in → cd /opt/loadtest && docker compose up -d
#
# STACK_NAME and AWS_REGION must match load-testing/infra/.env

# --- AWS (must match deployed stack) ---
STACK_NAME=loadtest-dev
AWS_REGION=ap-southeast-2

# --- Scale ---
AGENT_COUNT=1
# Defaults to AGENT_COUNT when unset
# EXPECTED_AGENT_COUNT=1

# --- Test parameters ---
INVITE_CODE=DEV-XXXXXX
NOTEBOOK_SERVER_ID=development-faims-server
NOTEBOOK_PROJECT_ID=your-project-id
NOTEBOOK_NAME=survey

# --- Scenario timing ---
# Agent: how long each browser creates records while offline.
OFFLINE_DURATION_MS=300000
# Coordinator: how long OFFLINE_COLLECTION lasts before SYNC_STORM (all agents reconnect).
# Must be >= OFFLINE_DURATION_MS. Unset → OFFLINE_DURATION_MS + 60000.
OFFLINE_COLLECTION_DURATION_MS=360000
# Agent: max wait for sync to finish after reconnect (increase for large offline backlogs).
SYNC_STORM_DELAY_MS=600000
# Coordinator: how long EXPORT_STRESS lasts before COMPLETE.
EXPORT_STRESS_DURATION_MS=15000
PARTICIPATE_IN_EXPORT=false

# --- Optional: override stack defaults for agent task env ---
# Leave unset to use CloudFormation outputs / task definition defaults.
# DASS_APP_URL=https://faims.example.com
# DASS_API_URL=https://conductor.example.com
# COUCH_URL=https://couchdb.example.com

# --- Script behaviour ---
WAIT_TIMEOUT_SEC=3600
