# Copy to .env in this directory (load-testing/scripts/)
#   cp .env.example .env
#   ./run-load-test.sh

# --- AWS (must match deployed stack) ---
STACK_NAME=loadtest-dev
AWS_REGION=ap-southeast-2

# --- Scale ---
AGENT_COUNT=1
# EXPECTED_AGENT_COUNT=1

# --- Test parameters ---
# Pre-seeded accounts (coordinator): email::password, comma-separated.
# Use :: not || — unquoted || is treated as bash "or" when this file is sourced.
# Generate with: ./seed-load-test-accounts.sh
LOAD_TEST_ACCOUNTS=loadtest-1@faims.test::LoadTestPass123!,loadtest-2@faims.test::LoadTestPass123!
NOTEBOOK_SERVER_ID=development-faims-server
NOTEBOOK_PROJECT_ID=your-project-id
NOTEBOOK_NAME=survey

# --- Sequence plan (required) ---
# Local JSON file — uploaded to stack S3 bucket by default (see SEQUENCE_PLAN_DELIVERY).
SEQUENCE_PLAN_FILE=../shared/sequence-plans/online-offline-loops-patchy.json

# Plan delivery for remote coordinator task:
#   s3  — upload SEQUENCE_PLAN_FILE to s3://<SequencePlansBucketName>/plans/<basename> (default)
#   env — pass SEQUENCE_PLAN_B64 in ECS override (8192-byte limit; small plans only)
# SEQUENCE_PLAN_DELIVERY=s3

# Skip upload when plan is already in the stack bucket (or another bucket the coordinator can read):
# SEQUENCE_PLAN_S3_URI=s3://loadtest-dev-sequenceplansbucket-abc123/plans/my-plan.json

# Legacy inline base64 (implies SEQUENCE_PLAN_DELIVERY=env when set):
# SEQUENCE_PLAN_B64=

PARTICIPATE_IN_EXPORT=false
WAIT_TIMEOUT_SEC=7200

# --- seed-load-test-accounts.sh (users only; uses api/.env, does NOT migrate CouchDB) ---
# LOAD_TEST_SEED_COUNT=10
# LOAD_TEST_SEED_PASSWORD=LoadTestPass123!
# LOAD_TEST_PROJECT_ID=   # defaults to NOTEBOOK_PROJECT_ID when set

# --- Cost estimate (optional: ./estimate-run-cost.sh 15) ---
# ESTIMATE_DURATION_MIN=15
# ESTIMATE_COORDINATOR_LEAD_MIN=3
# ESTIMATE_EGRESS_GB_PER_AGENT=0.2
# ESTIMATE_INCLUDE_METRICS_EC2=false
# COORDINATOR_CPU=2048
# COORDINATOR_MEMORY_MIB=4096
# AGENT_CPU=2048
# AGENT_MEMORY_MIB=4096
