{
  "name": "@faims3/load-testing-shared",
  "version": "1.5.2",
  "description": "Shared types and schemas for FAIMS load testing",
  "license": "Apache",
  "private": true,
  "files": [
    "build/src",
    "build/esm",
    "collection-profiles",
    "!build/**/*.tsbuildinfo"
  ],
  "bin": {
    "prepare-sequence-plan": "./build/src/prepare-sequence-plan.js"
  },
  "main": "./build/src/index.js",
  "module": "./build/esm/index.js",
  "types": "build/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/esm/src/index.d.ts",
        "default": "./build/esm/src/index.js"
      },
      "require": {
        "types": "./build/src/index.d.ts",
        "default": "./build/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run build:cjs && pnpm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "gts clean && rm -rf build",
    "lint": "oxlint -c ../../.oxlintrc.json ."
  },
  "dependencies": {
    "@faims3/instrumentation": "workspace:*",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.7.0"
}
