{
  "version": 1,
  "name": "split-online-patchy-loops",
  "description": "Onboarding, then 5×(2min: half online / half patchy split), then 4min all-online surveying.",
  "steps": [
    {
      "id": "onboarding",
      "kind": "onboarding",
      "label": "Register, activate notebook, initial sync",
      "advance": "all_agents_done",
      "config": {}
    },
    {
      "id": "mixed_cycles",
      "label": "Five rounds of 50/50 online vs patchy (2 min each branch)",
      "loop": {
        "count": 5,
        "steps": [
          {
            "id": "online_vs_patchy",
            "label": "Half agents online, half on patchy connectivity",
            "split": {
              "assignment": "agent_index_mod",
              "branches": [
                {
                  "id": "online_half",
                  "label": "Steady online",
                  "weight": 1,
                  "steps": [
                    {
                      "id": "cycle_online",
                      "kind": "online_collection",
                      "label": "Online surveying",
                      "durationMs": 120000,
                      "advance": "timer",
                      "config": {
                        "recordIntervalMs": 5000
                      }
                    }
                  ]
                },
                {
                  "id": "patchy_half",
                  "label": "Patchy connectivity",
                  "weight": 1,
                  "steps": [
                    {
                      "id": "cycle_patchy",
                      "kind": "patchy_network",
                      "label": "Patchy surveying (~30s cycles)",
                      "durationMs": 120000,
                      "advance": "timer",
                      "config": {
                        "cycleMs": 30000,
                        "cycleJitterMs": 8000,
                        "offlineDurationMs": 12000,
                        "offlineJitterMs": 4000,
                        "recordIntervalMs": 5000
                      }
                    }
                  ]
                }
              ]
            },
            "advance": "all_agents_done"
          }
        ]
      }
    },
    {
      "id": "all_online_finale",
      "kind": "online_collection",
      "label": "Everyone online — final survey push",
      "durationMs": 240000,
      "advance": "timer",
      "config": {
        "recordIntervalMs": 5000
      }
    }
  ]
}
