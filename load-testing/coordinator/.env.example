# Coordinator — copy to .env in this directory
#   pnpm run dev
#
# Requires a sequence plan and LOAD_TEST_ACCOUNTS at startup.

PORT=4000
EXPECTED_AGENT_COUNT=1
READINESS_TIMEOUT_MS=30000

# Pre-seeded users (from scripts/seed-load-test-accounts.sh): email::password, comma-separated
LOAD_TEST_ACCOUNTS=loadtest-1@faims.test::LoadTestPass123!,loadtest-2@faims.test::LoadTestPass123!

# Sequence plan — set ONE source (precedence: S3 URI → inline/base64 → file):
#
# Local dev (default):
SEQUENCE_PLAN_FILE=../shared/sequence-plans/legacy-default.json
#
# AWS ECS (set by run-load-test.sh):
# SEQUENCE_PLAN_S3_URI=s3://bucket/plans/legacy-default.json
#
# Inline (small plans / tests only):
# SEQUENCE_PLAN='{"version":1,"steps":[...]}'
# SEQUENCE_PLAN_B64=...

PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
# Minimum seconds between Pushgateway pushes (throttle, not debounce)
METRICS_PUSH_INTERVAL_MS=2000
