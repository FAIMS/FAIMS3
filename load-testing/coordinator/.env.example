# Coordinator — copy to .env in this directory
#   pnpm run dev
#
# Requires a sequence plan (JSON file or base64 env).

PORT=4000
EXPECTED_AGENT_COUNT=1
READINESS_TIMEOUT_MS=30000

# Sequence plan — use ONE of:
# SEQUENCE_PLAN='{"version":1,"steps":[...]}'
# SEQUENCE_PLAN_B64=...
# Or point at a file (local dev only):
SEQUENCE_PLAN_FILE=../shared/sequence-plans/legacy-default.json

PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
