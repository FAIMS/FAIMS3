# Coordinator — copy to .env and run from load-testing/coordinator/
#   pnpm run dev
#
# For Docker Compose, use load-testing/.env instead (see ../.env.example).

# Server
PORT=4000

# How many agent containers/workers must register before the run starts
EXPECTED_AGENT_COUNT=1

# Phase sequencing: all_ready | majority | timeout
PHASE_ADVANCE_STRATEGY=all_ready

# Max wait in WAITING_FOR_AGENTS before forcing ONBOARDING
READINESS_TIMEOUT_MS=30000

# Max wait on agent-reported phases when strategy=timeout
PHASE_TIMEOUT_MS=60000

# Timer length for OFFLINE_COLLECTION (coordinator advances to SYNC_STORM)
OFFLINE_COLLECTION_DURATION_MS=45000

# Timer length for EXPORT_STRESS (coordinator advances to COMPLETE)
EXPORT_STRESS_DURATION_MS=15000

# Optional — leave unset for local dev without Pushgateway
# PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
