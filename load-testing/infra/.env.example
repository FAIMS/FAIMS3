# Copy to .env in this directory before running cdk deploy / synth.
# All values are validated at synth time with Zod (see lib/config.ts).

# --- AWS / stack ---
STACK_NAME=loadtest-dev
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-southeast-2

# --- DNS (Route53) ---
# Hosted zone for metrics subdomain A record (EIP → loadtest-metrics.example.com)
HOSTED_ZONE_ID=Z1234567890ABC
HOSTED_ZONE_NAME=example.com
METRICS_SUBDOMAIN=loadtest-metrics

# --- Target DASS deployment (agents reach these over HTTPS) ---
DASS_APP_URL=https://faims.example.com
DASS_API_URL=https://conductor.example.com
COUCH_URL=https://couchdb.example.com

# CouchDB credentials for couchdb-exporter on the metrics EC2 instance.
# Prefer COUCH_PASSWORD_SECRET_ARN (JSON: {"username":"admin","password":"..."}).
# Use the full ARN from Secrets Manager (includes the 6-character suffix).
COUCH_USER=admin
COUCH_PASSWORD_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-2:123456789012:secret:my-couch-secret
# COUCH_PASSWORD=only-for-scratch-dev-without-secrets-manager

# --- Networking / compute ---
# Isolated VPC for load-test tasks and metrics EC2 (public subnets only, no NAT).
VPC_CIDR=10.30.0.0/16
METRICS_INSTANCE_TYPE=t3.medium

# Restrict Grafana (3030) access. Use your office/VPN CIDR in production.
ALLOWED_GRAFANA_CIDR=0.0.0.0/0

# Coordinator port (4000) - open for run-load-test.sh /health from your machine and agent tasks.
ALLOWED_COORDINATOR_CIDR=0.0.0.0/0

# --- ECS task sizing (Fargate) ---
COORDINATOR_CPU=2048
COORDINATOR_MEMORY_MIB=4096
AGENT_CPU=2048
AGENT_MEMORY_MIB=4096
