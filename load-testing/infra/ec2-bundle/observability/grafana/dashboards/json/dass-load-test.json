{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "expr": "dass_phase_transition_timestamp",
        "iconColor": "orange",
        "name": "Phase transitions",
        "tagKeys": "phase",
        "titleFormat": "Phase {{phase}}"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Test overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "dass_test_phase", "legendFormat": "phase"}],
      "title": "Current phase",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "targets": [{"expr": "dass_registered_agents", "legendFormat": "registered"}],
      "title": "Registered agents",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "targets": [{"expr": "dass_ready_agents", "legendFormat": "ready"}],
      "title": "Ready agents",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "targets": [{"expr": "dass_active_sessions", "legendFormat": "sessions"}],
      "title": "Active sessions",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 101,
      "title": "Browser performance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 5,
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(increase(dass_record_create_ms_bucket[$__range])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(increase(dass_record_create_ms_bucket[$__range])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(increase(dass_record_create_ms_bucket[$__range])) by (le))", "legendFormat": "p99"}
      ],
      "title": "Record create latency (selected range)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 6,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(dass_measure_duration_ms_bucket[$__rate_interval])) by (le, name))", "legendFormat": "{{name}}"}
      ],
      "title": "App measure duration (p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 7,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(dass_longtask_duration_ms_bucket[$__rate_interval])) by (le))", "legendFormat": "p95"}
      ],
      "title": "Long task duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 8,
      "targets": [{"expr": "dass_indexeddb_bytes", "legendFormat": "{{sessionId}}"}],
      "title": "IndexedDB size",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 102,
      "title": "Sync behaviour",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 9,
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(increase(dass_sync_duration_ms_bucket[$__range])) by (le, name))", "legendFormat": "{{name}} p50"},
        {"expr": "histogram_quantile(0.95, sum(increase(dass_sync_duration_ms_bucket[$__range])) by (le, name))", "legendFormat": "{{name}} p95"}
      ],
      "title": "Sync duration (selected range)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "id": 10,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(dass_couch_request_ms_bucket[$__rate_interval])) by (le))", "legendFormat": "client p95"},
        {"expr": "couchdb_httpd_request_time", "legendFormat": "server last request (ms)"}
      ],
      "title": "CouchDB request latency (client vs server)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "id": 103,
      "title": "CouchDB internals",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 34},
      "id": 11,
      "targets": [{"expr": "sum(couchdb_fabric_worker)", "legendFormat": "fabric workers"}],
      "title": "Active tasks",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 34},
      "id": 12,
      "targets": [{"expr": "sum(couchdb_replicator_jobs{metric=\"pending\"})", "legendFormat": "pending"}],
      "title": "Pending replicator jobs",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 34},
      "id": 13,
      "targets": [{"expr": "rate(couchdb_httpd_database_writes[$__rate_interval])", "legendFormat": "writes/s"}],
      "title": "Write throughput",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["dass", "load-test"],
  "templating": {
    "list": [
