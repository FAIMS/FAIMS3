# Observability stack — copy to .env in load-testing/
#   make observability
#
# Coordinator and agents have their own .env files — see coordinator/.env.example
# and agents/.env.example.

# CouchDB target for couchdb-exporter (must reach the host from inside Docker)
COUCHDB_EXPORTER_URL=http://host.docker.internal:5984
COUCH_USER=admin
COUCH_PASSWORD=aSecretPasswordThatCantBeGuessed
# gesellix reads COUCHDB_* — bootstrap copies these on EC2; set both locally too
COUCHDB_USERNAME=admin
COUCHDB_PASSWORD=aSecretPasswordThatCantBeGuessed

# Published ports (host)
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
GRAFANA_PORT=3030
COUCHDB_EXPORTER_PORT=9984
COUCHDB_EXPORTER_VERSION=latest
