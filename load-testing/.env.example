# Docker Compose stack — copy to .env in this directory (load-testing/)
#   make test
#   docker compose up ...
#
# Used by: coordinator, agent, couchdb-exporter services.
# For local dev without Docker, see coordinator/.env.example and agents/.env.example.

# --- Target FAIMS stack (host machine from container) ---
DASS_APP_URL=http://host.docker.internal:3000
DASS_API_URL=http://host.docker.internal:8080
COUCH_URL=http://host.docker.internal:5984
COUCH_USER=admin
COUCH_PASSWORD=aSecretPasswordThatCantBeGuessed

# --- Test parameters ---
INVITE_CODE=DEV-XXXXXX
NOTEBOOK_SERVER_ID=local-dev
NOTEBOOK_PROJECT_ID=your-project-id
RECORD_VIEW_ID=
AGENT_COUNT=1
SESSIONS_PER_AGENT=1
PARTICIPATE_IN_EXPORT=false

# Agent offline loop duration (browser session)
OFFLINE_DURATION_MS=30000

# Coordinator phase timers (must be >= agent work where relevant)
OFFLINE_COLLECTION_DURATION_MS=45000
SYNC_STORM_DELAY_MS=60000
EXPORT_STRESS_DURATION_MS=15000

# --- Coordinator ---
EXPECTED_AGENT_COUNT=1
READINESS_TIMEOUT_MS=30000
PHASE_ADVANCE_STRATEGY=all_ready
PHASE_TIMEOUT_MS=60000

# --- Published ports (host) ---
COORDINATOR_PORT=4000
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
GRAFANA_PORT=3030
COUCHDB_EXPORTER_PORT=9984
COUCHDB_EXPORTER_VERSION=latest

# --- Agent browser ---
HEADLESS=true
BROWSER=chromium
SLOW_MO=0
VIEWPORT_WIDTH=393
VIEWPORT_HEIGHT=852
USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15

# --- Staging (uncomment and adjust) ---
# DASS_APP_URL=https://app.staging.example.com
# DASS_API_URL=https://api.staging.example.com
# COUCH_URL=https://couchdb.staging.example.com
