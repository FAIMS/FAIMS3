# Agents — copy to .env and run from load-testing/agents/
#   pnpm run install-browsers   # first time only
#   pnpm run dev
#
# For Docker Compose, use load-testing/.env instead (see ../.env.example).
# URLs below target a FAIMS stack on the host machine (not inside Docker).

# Coordinator
COORDINATOR_URL=http://localhost:4000

# Target FAIMS stack (host-run local dev)
DASS_APP_URL=http://localhost:3000
DASS_API_URL=http://localhost:8080
COUCH_URL=http://localhost:5984

# Test parameters — create a multi-use invite in web admin first
INVITE_CODE=DEV-XXXXXX
NOTEBOOK_SERVER_ID=development-faims-server
NOTEBOOK_PROJECT_ID=your-project-id
RECORD_VIEW_ID=

# Worker layout
SESSIONS_PER_AGENT=1

# Scenario timing (agent-side) — defaults tuned for rapid smoke testing
OFFLINE_DURATION_MS=30000
SYNC_STORM_DELAY_MS=60000
PARTICIPATE_IN_EXPORT=false

# Browser
HEADLESS=true
BROWSER=chromium
SLOW_MO=0
VIEWPORT_WIDTH=393
VIEWPORT_HEIGHT=852
USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15
