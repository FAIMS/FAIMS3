# Agents — copy to .env in this directory
#   pnpm run install-browsers   # first time only
#   pnpm run dev
#
# Sequence plan / step timing is coordinator-side (SEQUENCE_PLAN_FILE or SEQUENCE_PLAN_S3_URI).
# Agents only need COORDINATOR_URL — they poll GET /step for the current step.

COORDINATOR_URL=http://localhost:4000

FAIMS_APP_URL=http://localhost:3000
FAIMS_API_URL=http://localhost:8080
COUCH_URL=http://localhost:5984

# Credentials come from coordinator GET /credentials (LOAD_TEST_ACCOUNTS on coordinator)
NOTEBOOK_SERVER_ID=development-faims-server
NOTEBOOK_PROJECT_ID=your-project-id
NOTEBOOK_NAME=survey

SESSIONS_PER_AGENT=1
PARTICIPATE_IN_EXPORT=false

HEADLESS=true
SLOW_MO=0
VIEWPORT_WIDTH=393
VIEWPORT_HEIGHT=852
