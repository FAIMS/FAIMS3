# Agents — copy to .env in this directory
#   pnpm run install-browsers   # first time only
#   pnpm run dev
#
# Build and run in Docker (from monorepo root):
#   docker build -f load-testing/agents/Dockerfile -t load-test-agent .
#   docker run --env-file load-testing/agents/.env \
#     --shm-size=2g --add-host=host.docker.internal:host-gateway \
#     load-test-agent
#
# For Docker, point URLs at the host machine:
#   DASS_APP_URL=http://host.docker.internal:3000
#   COORDINATOR_URL=http://host.docker.internal:4000

COORDINATOR_URL=http://localhost:4000

# Target FAIMS stack
DASS_APP_URL=http://localhost:3000
DASS_API_URL=http://localhost:8080
COUCH_URL=http://localhost:5984

# Test parameters — create a multi-use invite in web admin first
INVITE_CODE=DEV-XXXXXX
NOTEBOOK_SERVER_ID=development-faims-server
NOTEBOOK_PROJECT_ID=your-project-id

# Notebook route segment — used for dynamic URLs, e.g. survey → /surveys/{server}/{project}
NOTEBOOK_NAME=survey

# Worker layout
SESSIONS_PER_AGENT=1

# Scenario timing (agent-side)
OFFLINE_DURATION_MS=30000
SYNC_STORM_DELAY_MS=60000
PARTICIPATE_IN_EXPORT=false

# Browser
HEADLESS=true
SLOW_MO=0
VIEWPORT_WIDTH=393
VIEWPORT_HEIGHT=852
USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15
