{
  "name": "@faims3/forms",
  "version": "1.4.4",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --p ./tsconfig-build.json && vite build",
    "watch": "pnpm run watch:types & pnpm run watch:build",
    "watch:types": "tsc --p ./tsconfig-build.json --watch",
    "watch:build": "vite build --watch",
    "circular-dep-check": "madge -c --extensions ts lib/",
    "lint": "(pnpm run circular-dep-check || exit 0) && oxlint --config ../../.oxlintrc.json .",
    "fix": "oxlint --config ../../.oxlintrc.json --fix . && oxfmt --config ../../.oxfmtrc.json .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@capacitor-community/exif": "^7.0.0",
    "@capacitor-mlkit/barcode-scanning": "^7.2.1",
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/geolocation": "^7.1.5",
    "@capgo/capacitor-speech-recognition": "^8.0.4",
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.10.8",
    "@faims3/data-model": "workspace:*",
    "@mui/icons-material": "5.15.8",
    "@mui/lab": "5.0.0-alpha.129",
    "@mui/material": "5.15.14",
    "@tanstack/react-form": "^1.23.8",
    "@tanstack/react-query": "^5.62.16",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "mustache": "^4.2.0",
    "proj4": "^2.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "14.2.3",
    "react-router-dom": "^6.26.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.4.6",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/mustache": "^4.2.6",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "madge": "^8.0.0",
    "ol": "^10.3.1",
    "ol-mapbox-style": "^12.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^4.0.6"
  },
  "peerDependencies": {
    "@capacitor-community/exif": "^7.0.0",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/geolocation": "^7.1.1",
    "@tanstack/react-query": "^5.62.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.7.0"
}
