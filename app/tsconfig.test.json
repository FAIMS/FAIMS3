{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "node",
      "vitest/globals",
      "vite/client",
      "vite-plugin-svgr/client",
      "@testing-library/jest-dom"
    ]
  },
  "include": [
    "src//*.test.ts",
    "src//.test.tsx",
    "src/**/.spec.ts",
    "src/**/*.spec.tsx",
    "src/setupTests.ts"
  ]
}
