{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "designer": ["../designer/src"]
    },
    "outDir": "dist",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["vite/client"]
  }
}
