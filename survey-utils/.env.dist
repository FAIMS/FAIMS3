# MUI theme for field preview screenshots (same values as app: default, fieldmark, bssTheme)
VITE_THEME=default

# Map tiles for field preview screenshots (MapFormField previews)
# Set to one of 'osm', 'maptiler', ''
VITE_MAP_SOURCE=osm
# Optional key for the map tile service, e.g. maptiler
VITE_MAP_SOURCE_KEY=
# Map style: basic (default), osm-bright, openstreetmap, toner
VITE_MAP_STYLE=basic
# Optional satellite source: esri | maptiler
# VITE_SATELLITE_SOURCE=
