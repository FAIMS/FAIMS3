VITE_DASHBOARD_URL=http://localhost:3002
VITE_API_URL=http://localhost:8080

# CouchDB URL for dashboard one-way sync (default: http://localhost:5984)
VITE_COUCHDB_URL=http://localhost:5984



# Optional: dashboard window title
VITE_DASHBOARD_TITLE="FAIMS Dashboard"

# Map configuration for OpenLayers / FAIMS maps
# Set to one of 'osm', 'maptiler', or leave empty for defaults
VITE_MAP_SOURCE=maptiler
# Optional key for the map tile service (e.g. MapTiler)
VITE_MAP_SOURCE_KEY=<your maptiler key here>
# Map style can be 'basic' (default), 'osm-bright', 'openstreetmap', 'toner'
VITE_MAP_STYLE=basic
# To enable satellite maps (optional)
# VITE_SATELLITE_SOURCE=maptiler

# Optional: Bugsnag error reporting for the dashboard
# VITE_BUGSNAG_API_KEY=your_bugsnag_api_key_here

