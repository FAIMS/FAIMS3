{
  "name": "faims3",
  "version": "1.4.3",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "build-app": "pnpm --filter=app run build",
    "build-api": "pnpm --filter=api run build",
    "build-data-model": "pnpm --filter=data-model run build",
    "github-build-app": "pnpm exec turbo build --filter=@faims3/app --force",
    "docker-build-api": "pnpm exec turbo build --filter=@faims3/api --force",
    "build-aws": "pnpm --filter=aws-cdk run build",
    "package-aws": "pnpm --filter=aws-cdk run package",
    "test-app": "pnpm --filter=app test",
    "serve-app": "pnpm --filter=app run serve",
    "start": "pnpm --filter=api --filter=app start",
    "start-api": "pnpm --filter=api start",
    "start-app": "pnpm --filter=app start",
    "start-web": "pnpm --filter=web start",
    "force-start-app": "pnpm --filter=app force-start",
    "watch-api": "pnpm --filter=api run local",
    "web-dev": "pnpm --filter=web run dev",
    "migrate": "pnpm --filter=api run migrate",
    "migrate-with-keys": "pnpm --filter=api run migrate-with-keys",
    "load-projects": "pnpm --filter=api run load-projects",
    "load-templates": "pnpm --filter=api run load-templates",
    "generate-local-keys": "./api/keymanagement/makeInstanceKeys.sh",
    "build-web": "turbo build --filter @faims3/web",
    "dev": "turbo dev --filter=@faims3/app --filter=@faims3/web --filter=@faims3/api --filter=@faims3/data-model --parallel",
    "lint": "turbo lint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "clean": "turbo clean",
    "build": "turbo build",
    "knip": "knip"
  },
  "dependencies": {
    "@capacitor-community/exif": "^7.0.0",
    "env-cmd": "^10.1.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "gts": "^5.3.1",
    "knip": "^5.75.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.0.11",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.7.0",
  "pnpm": {
    "overrides": {
      "@mui/base": "5.0.0-beta.40"
    }
  }
}
