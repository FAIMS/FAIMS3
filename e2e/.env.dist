# directory to write screenshots into
SCREENSHOT_DIR=./screenshots
# Run artifacts (screenshots, manifest, junit, failure dumps)
ARTIFACT_DIR=./artifacts
# off | on | docs | artifacts | all
SCREENSHOT_MODE=all
# WDIO protocol log level: silent | error | warn | info | debug | trace
# Default warn keeps CI readable; use info/debug when diagnosing WebDriver commands
WDIO_LOG_LEVEL=warn
# URL of the web version of the data collection app
WEB_APP_PUBLIC_URL=http://localhost:3000
# URL of the control center app to test
WEB_URL=http://localhost:3001
NEW_CONDUCTOR_URL=http://localhost:3001
# Conductor / API auth pages
CONDUCTOR_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Seed dataset credentials (api/src/scripts/seedTestDataset.ts)
# -----------------------------------------------------------------------------

# Shared e2e role credentials used by both app and web tests
TEST_OPERATIONS_ADMIN_USERNAME=seed-admin@faims.test
TEST_OPERATIONS_ADMIN_PASSWORD=TestPassword123!
