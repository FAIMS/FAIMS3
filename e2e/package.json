{
  "name": "@faims3/e2e",
  "version": "1.6.2",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint -c ../.oxlintrc.json .",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "fix": "oxlint -c ../.oxlintrc.json --fix . && oxfmt -c ../.oxfmtrc.json .",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:e2e:app": "wdio run wdio.conf.ts",
    "test:e2e:mobile": "VIEWPORT=mobile pnpm run test:e2e",
    "test:e2e:tablet": "VIEWPORT=tablet pnpm run test:e2e",
    "test:e2e:desktop": "VIEWPORT=desktop pnpm run test:e2e",
    "test:e2e:wide": "VIEWPORT=wide pnpm run test:e2e",
    "test:e2e:all": "pnpm run test:e2e:mobile && pnpm run test:e2e:tablet && pnpm run test:e2e:desktop && pnpm run test:e2e:wide",
    "test:e2e:android": "wdio run wdio.mobile.conf.ts",
    "test:e2e:ios": "PLATFORM=ios wdio run wdio.mobile.conf.ts",
    "test:e2e:web": "wdio run wdio.web.conf.ts",
    "test:e2e:web:desktop": "VIEWPORT=desktop pnpm run test:e2e:web",
    "test:e2e:web:wide": "VIEWPORT=wide pnpm run test:e2e:web",
    "test:e2e:web:all": "pnpm run test:e2e:web:desktop && pnpm run test:e2e:web:wide",
    "test:e2e:smoke": "wdio run wdio.smoke.conf.ts",
    "test:e2e:headless": "wdio run wdio.headless.conf.ts",
    "test:e2e:headless:app": "wdio run wdio.headless.conf.ts",
    "test:e2e:headless:mobile": "VIEWPORT=mobile pnpm run test:e2e:headless",
    "test:e2e:headless:tablet": "VIEWPORT=tablet pnpm run test:e2e:headless",
    "test:e2e:headless:desktop": "VIEWPORT=desktop pnpm run test:e2e:headless",
    "test:e2e:headless:wide": "VIEWPORT=wide pnpm run test:e2e:headless",
    "test:e2e:headless:all": "pnpm run test:e2e:headless:mobile && pnpm run test:e2e:headless:tablet && pnpm run test:e2e:headless:desktop && pnpm run test:e2e:headless:wide",
    "test:e2e:headless:web": "wdio run wdio.headless.web.conf.ts",
    "test:e2e:headless:web:desktop": "VIEWPORT=desktop pnpm run test:e2e:headless:web",
    "test:e2e:headless:web:wide": "VIEWPORT=wide pnpm run test:e2e:headless:web",
    "test:e2e:headless:web:all": "pnpm run test:e2e:headless:web:desktop && pnpm run test:e2e:headless:web:wide",
    "test:e2e:headless:smoke": "wdio run wdio.headless.smoke.conf.ts",
    "test:e2e:headless:ci": "pnpm run test:e2e:headless:smoke && pnpm run test:e2e:headless:web && pnpm run test:e2e:headless",
    "report": "node --experimental-strip-types scripts/generate-report.ts"
  },
  "devDependencies": {
    "@testing-library/webdriverio": "^3.2.1",
    "@wdio/appium-service": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/junit-reporter": "^9.29.1",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "@wdio/types": "^9.27.2",
    "appium": "^2.11.5",
    "appium-uiautomator2-driver": "^3.10.0",
    "chromedriver": "^138.0.4",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.6.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wdio-wait-for": "^3.1.0"
  }
}
