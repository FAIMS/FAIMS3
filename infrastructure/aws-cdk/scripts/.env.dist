# Copy to scripts/.env and fill in. scripts/.env is gitignored.

# --- Couch baseline (pnpm run couch-upgrade-baseline) ---
COUCH_URL=https://stage-couchdb.example.com
COUCHDB_USER=admin
COUCHDB_PASSWORD=

# Comma-separated DB names to record doc_count / update_seq for
MARKER_DBS=

# --- EC2 / EBS (snapshot + prepare-replace scripts) ---
# CloudFormation stack name (configs/<env>.json → stackName). Used by
# `pnpm run couch-upgrade-baseline -- --instance-id` to resolve EC2_INSTANCE_ID.
STACK_NAME=
# Filled automatically with --instance-id, or set manually.
EC2_INSTANCE_ID=i-0123456789abcdef0
# Optional. Leave unset/blank to use your shell / AWS config region.
# AWS_REGION=ap-southeast-2
# Couch data volume device (CDK default).
EC2_DATA_DEVICE=/dev/xvdf
# Optional. Set if the data volume is already detached (prepare-replace).
# EC2_VOLUME_ID=vol-0123456789abcdef0
